<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
{squarespace-headers}
<style>
  :root{
    --navy:#0F1E33;
    --navy-deep:#0A1626;
    --navy-panel:#15263F;
    --gold:#C9A227;
    --gold-lite:#E4C766;
    --cream:#F6F3EC;
    --ink:#1C2533;
    --slate:#4F5A6B;
    --muted:#8A94A3;
    --line:rgba(255,255,255,.12);
    --line-dark:rgba(15,30,51,.12);
    --hero-img:url("data:image/jpeg;base64,");
    --serif:'Fraunces',Georgia,serif;
    --sans:'Inter',system-ui,sans-serif;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{font-family:var(--sans);color:var(--ink);background:var(--cream);line-height:1.6;-webkit-font-smoothing:antialiased}
  h1,h2,h3{font-family:var(--serif);font-weight:500;line-height:1.1;letter-spacing:-.01em}
  a{color:inherit;text-decoration:none}
  .wrap{max-width:1180px;margin:0 auto;padding:0 32px}
  .eyebrow{font-family:var(--sans);font-size:12px;font-weight:600;letter-spacing:.22em;text-transform:uppercase;color:var(--gold)}

  /* ---------- Logo ---------- */
  .logo{display:flex;align-items:center;gap:14px}
  .logo svg{display:block;height:42px;width:auto}
  .logo .lockup{display:flex;flex-direction:column;line-height:1}
  .logo .lockup .firm{font-family:var(--sans);font-weight:600;font-size:12.5px;letter-spacing:.13em;color:#fff}
  .logo .lockup .sub{font-family:var(--sans);font-weight:500;font-size:9.5px;letter-spacing:.32em;color:var(--gold);margin-top:5px}

  /* ---------- Header ---------- */
  header{position:absolute;top:0;left:0;right:0;z-index:40}
  .topbar{border-bottom:1px solid var(--line)}
  .topbar .wrap{display:flex;justify-content:flex-end;gap:26px;padding-top:10px;padding-bottom:10px;font-size:12.5px;color:rgba(255,255,255,.72);letter-spacing:.03em}
  .topbar a:hover{color:var(--gold-lite)}
  .nav{display:flex;align-items:center;justify-content:space-between;padding-top:22px;padding-bottom:22px}
  .nav ul{display:flex;align-items:center;gap:30px;list-style:none}
  .nav ul a{font-size:13.5px;font-weight:500;letter-spacing:.04em;color:rgba(255,255,255,.85);padding-bottom:4px;border-bottom:1.5px solid transparent;transition:.2s}
  .nav ul a:hover{color:#fff;border-color:var(--gold)}
  .btn{display:inline-block;font-family:var(--sans);font-size:13px;font-weight:600;letter-spacing:.04em;padding:12px 22px;border-radius:2px;transition:.2s;cursor:pointer;border:1px solid transparent}
  .btn-gold{background:var(--gold);color:var(--navy-deep)}
  .btn-gold:hover{background:var(--gold-lite)}
  .btn-ghost{border-color:rgba(255,255,255,.35);color:#fff}
  .btn-ghost:hover{border-color:var(--gold);color:var(--gold-lite)}
  .menu-toggle{display:none;background:none;border:0;cursor:pointer;flex-direction:column;gap:5px;padding:6px}
  .menu-toggle span{width:24px;height:2px;background:#fff;display:block}

  /* ---------- Hero ---------- */
  .hero{position:relative;background:linear-gradient(90deg,rgba(9,19,34,.94) 0%,rgba(11,24,42,.74) 40%,rgba(11,24,42,.34) 100%),linear-gradient(180deg,rgba(9,19,34,.55) 0%,rgba(9,19,34,.22) 38%,rgba(8,17,30,.9) 100%),var(--hero-img) center/cover no-repeat;color:#fff;overflow:hidden;padding:210px 0 130px}
  .hero .mono-bg{position:absolute;right:-60px;top:50%;transform:translateY(-50%);height:118%;opacity:.10;pointer-events:none}
  .hero .mono-bg svg{height:100%;width:auto;display:block}
  .hero .wrap{position:relative;z-index:2;max-width:1180px}
  .hero h1{font-size:clamp(40px,6vw,76px);margin:22px 0 0;max-width:14ch}
  .hero h1 em{font-style:italic;color:var(--gold-lite)}
  .hero .lede{font-size:clamp(16px,1.8vw,19px);color:rgba(255,255,255,.78);max-width:54ch;margin-top:26px}
  .hero .cta-row{display:flex;flex-wrap:wrap;gap:14px;margin-top:38px}
  .hero .rule{width:64px;height:2px;background:var(--gold);margin-bottom:4px}

  /* ---------- Section primitives ---------- */
  section{padding:96px 0}
  .sec-head{max-width:62ch}
  .sec-head h2{font-size:clamp(30px,4vw,46px);margin:16px 0 0}
  .sec-head p{color:var(--slate);font-size:17px;margin-top:20px}
  .center{text-align:center;margin-left:auto;margin-right:auto}

  /* ---------- About strip ---------- */
  .about{background:#fff}
  .about-grid{display:grid;grid-template-columns:1.15fr 1fr;gap:64px;align-items:center}
  .about-grid p{color:var(--slate);font-size:16.5px;margin-top:18px}
  .about-aside{background:var(--navy);color:#fff;padding:44px;border-radius:3px;position:relative;overflow:hidden}
  .about-aside .eyebrow{color:var(--gold-lite)}
  .about-aside .stat{padding:22px 0;border-bottom:1px solid var(--line)}
  .about-aside .stat:last-child{border-bottom:0;padding-bottom:0}
  .about-aside .stat .n{font-family:var(--serif);font-size:34px;color:var(--gold-lite);line-height:1}
  .about-aside .stat .l{font-size:14px;color:rgba(255,255,255,.72);margin-top:6px}

  /* ---------- Difference cards ---------- */
  .diff{background:var(--cream)}
  .cards{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:54px}
  .card{background:#fff;padding:38px 32px;border:1px solid var(--line-dark);border-top:3px solid var(--gold);border-radius:3px;transition:.25s}
  .card:hover{transform:translateY(-4px);box-shadow:0 18px 40px -24px rgba(15,30,51,.4)}
  .card .num{font-family:var(--serif);font-size:15px;color:var(--gold);letter-spacing:.05em}
  .card h3{font-size:22px;margin:14px 0 12px}
  .card p{color:var(--slate);font-size:15.5px}

  /* ---------- Who we serve ---------- */
  .serve{background:var(--navy);color:#fff}
  .serve .sec-head p{color:rgba(255,255,255,.74)}
  .serve-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:1px;margin-top:54px;background:var(--line);border:1px solid var(--line)}
  .serve-grid .cell{background:var(--navy);padding:34px 24px;text-align:center}
  .serve-grid .cell svg{height:30px;width:30px;stroke:var(--gold);fill:none;stroke-width:1.4;margin-bottom:16px}
  .serve-grid .cell .t{font-family:var(--serif);font-size:18px}
  .serve-grid .cell .d{font-size:13px;color:rgba(255,255,255,.6);margin-top:8px}

  /* ---------- Coverage (signature) ---------- */
  .coverage{background:#fff}
  .cov-grid{display:grid;grid-template-columns:1fr;gap:56px;align-items:center;margin-top:50px}
  .ca-map svg{width:100%;height:auto;display:block}
  .venues{display:grid;grid-template-columns:1fr 1fr;gap:40px}
  .venues .col h3{font-size:20px;display:flex;align-items:center;gap:10px}
  .venues .col h3 .dot{width:9px;height:9px;background:var(--gold);border-radius:50%;display:inline-block}
  .venues .office{font-size:13px;color:var(--muted);letter-spacing:.04em;text-transform:uppercase;font-weight:600;margin:6px 0 18px}
  .venues ul{list-style:none;columns:2;column-gap:24px}
  .venues li{font-size:15px;color:var(--slate);padding:5px 0;border-bottom:1px solid var(--line-dark);break-inside:avoid}

  /* ---------- Attorneys ---------- */
  .team{background:var(--cream)}
  .team-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px;margin-top:54px}
  .att{background:#fff;border:1px solid var(--line-dark);border-radius:3px;overflow:hidden;transition:.25s}
  .att:hover{box-shadow:0 18px 40px -24px rgba(15,30,51,.45)}
  .att .photo{aspect-ratio:4/3.4;background:radial-gradient(120% 120% at 70% 20%,#1b3052,var(--navy-deep));display:flex;align-items:center;justify-content:center}
  .att .photo .ini{font-family:var(--serif);font-size:54px;color:var(--gold-lite);opacity:.92}
  .att .meta{padding:24px 26px}
  .att .meta .nm{font-family:var(--serif);font-size:23px}
  .att .meta .ttl{font-size:13px;letter-spacing:.06em;text-transform:uppercase;color:var(--gold);font-weight:600;margin-top:5px}
  .att .meta p{color:var(--slate);font-size:14.5px;margin-top:12px}
  .team-foot{text-align:center;margin-top:44px;color:var(--slate)}
  .team-foot a{color:var(--gold);font-weight:600;border-bottom:1px solid var(--gold)}

  /* ---------- CTA band ---------- */
  .cta{background:linear-gradient(rgba(8,17,30,.86),rgba(7,15,27,.93)),var(--hero-img) center/cover no-repeat;color:#fff;text-align:center}
  .cta h2{font-size:clamp(28px,4vw,44px);max-width:20ch;margin:0 auto}
  .cta p{color:rgba(255,255,255,.76);max-width:52ch;margin:22px auto 0;font-size:17px}
  .cta .cta-row{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-top:36px}

  /* ---------- Footer ---------- */
  footer{background:var(--navy-deep);color:rgba(255,255,255,.7);padding:64px 0 30px}
  .foot-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:40px}
  footer h4{font-family:var(--sans);font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--gold);margin-bottom:18px}
  footer ul{list-style:none}
  footer li{padding:5px 0;font-size:14.5px}
  footer a:hover{color:#fff}
  .foot-bottom{border-top:1px solid var(--line);margin-top:48px;padding-top:24px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;font-size:12.5px;color:var(--muted)}

  /* ---------- Reveal ---------- */
  .reveal{opacity:0;transform:translateY(22px);transition:opacity .7s ease,transform .7s ease}
  .reveal.in{opacity:1;transform:none}
  @media (prefers-reduced-motion:reduce){.reveal{opacity:1;transform:none;transition:none}}

  /* ---------- Responsive ---------- */
  @media(max-width:900px){
    .menu-toggle{display:flex}
    .nav ul{position:absolute;top:100%;left:0;right:0;flex-direction:column;align-items:flex-start;gap:0;background:var(--navy-deep);padding:8px 32px;max-height:0;overflow:hidden;transition:max-height .3s}
    .nav ul.open{max-height:420px;padding:18px 32px 26px}
    .nav ul li{width:100%}
    .nav ul a{display:block;padding:13px 0;border-bottom:1px solid var(--line)}
    .topbar{display:none}
    .about-grid,.cov-grid{grid-template-columns:1fr;gap:40px}
    .cards,.team-grid{grid-template-columns:1fr}
    .serve-grid{grid-template-columns:1fr 1fr}
    .foot-grid{grid-template-columns:1fr 1fr}
    .hero{padding:170px 0 96px}
  }
  @media(max-width:520px){
    .wrap{padding:0 22px}
    .venues{grid-template-columns:1fr}
    .venues ul{columns:1}
    .serve-grid{grid-template-columns:1fr}
    .foot-grid{grid-template-columns:1fr}
  }
</style>
</head>
<body>

<!-- ===== Reusable monogram defined once ===== -->
<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <linearGradient id="goldGrad" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#E4C766"/>
      <stop offset="1" stop-color="#B8901E"/>
    </linearGradient>
    <g id="meMono">
      <!-- M: two full legs + shallow center V -->
      <rect x="8" y="8" width="27" height="132" fill="url(#goldGrad)"/>
      <rect x="92" y="8" width="27" height="132" fill="url(#goldGrad)"/>
      <path d="M8 8 L35 8 L75 100 L48 100 Z" fill="url(#goldGrad)"/>
      <path d="M119 8 L92 8 L52 100 L79 100 Z" fill="url(#goldGrad)"/>
      <!-- E: spine + three arms -->
      <rect x="131" y="8" width="25" height="132" fill="url(#goldGrad)"/>
      <rect x="131" y="8" width="80" height="25" fill="url(#goldGrad)"/>
      <rect x="131" y="66" width="62" height="24" fill="url(#goldGrad)"/>
      <rect x="131" y="115" width="80" height="25" fill="url(#goldGrad)"/>
      <!-- LAW tucked into the E -->
      <text x="167" y="109" font-family="Inter,sans-serif" font-size="15" font-weight="600" letter-spacing="3.5" fill="url(#goldGrad)">LAW</text>
    </g>
  </defs>
</svg>

<header>
  <div class="topbar">
    <div class="wrap">
      <a href="tel:+19493730777">p 949.373.0777</a>
      <span>Orange County · Sacramento · San Diego</span>
    </div>
  </div>
  <nav class="nav wrap" aria-label="Primary">
    <a href="#top" class="logo" aria-label="MacDonald Ebbing and Lloyd, LLP home">
      <svg viewBox="0 0 219 148" role="img"><use href="#meMono"/></svg>
      <span class="lockup">
        <span class="firm">MACDONALD EBBING &amp; LLOYD, LLP</span>
      </span>
    </a>
    <ul id="menu">
      <li><a href="#about">About</a></li>
      <li><a href="#difference">Why Us</a></li>
      <li><a href="#serve">Clients</a></li>
      <li><a href="#coverage">Coverage</a></li>
      <li><a href="#team">Attorneys</a></li>
      <li><a href="#contact" class="btn btn-gold">Contact</a></li>
    </ul>
    <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false"><span></span><span></span><span></span></button>
  </nav>
</header>

<main id="top">
  <!-- ===== HERO ===== -->
  <section class="hero" id="hero">
    <div class="wrap">
      <div class="rule"></div>
      <span class="eyebrow">California Workers' Compensation Defense</span>
      <h1>Statewide defense. <em>Singular focus.</em></h1>
      <p class="lede">A results-focused defense firm built to protect employers, insurance carriers, and third-party administrators — with aggressive litigation, disciplined cost control, and clear communication at every stage of a claim.</p>
      <div class="cta-row">
        <a href="#contact" class="btn btn-gold">Partner with our firm</a>
        <a href="#team" class="btn btn-ghost">Meet the attorneys</a>
      </div>
    </div>
  </section>

  <!-- ===== ABOUT ===== -->
  <section class="about" id="about">
    <div class="wrap about-grid">
      <div class="reveal">
        <span class="eyebrow">About the firm</span>
        <h2 class="sec-head" style="font-size:clamp(30px,4vw,46px);margin-top:16px">A legal firm that defends like your business partner.</h2>
        <p>MacDonald Ebbing &amp; Lloyd, LLP is a results-focused defense firm specializing in California workers' compensation and employment litigation. We represent clients across the full spectrum — from Fortune 500 companies to uninsured employers, insurance carriers, and third-party administrators.</p>
        <p>We deliver favorable, efficient results: pairing aggressive litigation strategy with the judgment to seize cost-saving opportunities for early resolution at every claim stage. Choosing your attorney is as important as choosing your business partner — and we approach the relationship that way, from claim inception to closure.</p>
      </div>
      <aside class="about-aside reveal">
        <span class="eyebrow">At a glance</span>
        <div class="stat" style="margin-top:18px"><div class="n">Southern and Northern California Offices</div><div class="l">Orange County · Sacramento · San Diego</div></div>
        <div class="stat"><div class="n">19 WCAB Venues</div><div class="l">Covering all venues across California</div></div>
        <div class="stat"><div class="n">Results</div><div class="l">A results-driven approach on every matter, from inception to closure</div></div>
      </aside>
    </div>
  </section>

  <!-- ===== DIFFERENCE ===== -->
  <section class="diff" id="difference">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow">What sets us apart</span>
        <h2>Built around the result, not the billable hour.</h2>
        <p>Every decision is measured against the outcome it produces for the client. Three commitments shape how we handle every claim.</p>
      </div>
      <div class="cards">
        <div class="card reveal"><div class="num">01</div><h3>Aggressive litigation</h3><p>We build defensible positions early and litigate with intent — protecting our clients' exposure rather than simply processing files.</p></div>
        <div class="card reveal"><div class="num">02</div><h3>Cost-saving resolution</h3><p>When early resolution serves the client, we recognize it and act on it, controlling cost at every stage of the claim lifecycle.</p></div>
        <div class="card reveal"><div class="num">03</div><h3>Service &amp; communication</h3><p>Clear, responsive reporting that keeps employers, carriers, and administrators informed and confident in every decision.</p></div>
      </div>
    </div>
  </section>

  <!-- ===== WHO WE SERVE ===== -->
  <section class="serve" id="serve">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow">Who we represent</span>
        <h2>Defense for those who carry the risk.</h2>
        <p>We have represented clients from all spectrums of the workers' compensation system.</p>
      </div>
      <div class="serve-grid reveal">
        <div class="cell"><svg viewBox="0 0 24 24"><path d="M3 21h18M5 21V7l7-4 7 4v14M9 21v-6h6v6"/></svg><div class="t">Employers</div><div class="d">Fortune 500 to small business</div></div>
        <div class="cell"><svg viewBox="0 0 24 24"><path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6z"/></svg><div class="t">Insurance Carriers</div><div class="d">Claim defense &amp; strategy</div></div>
        <div class="cell"><svg viewBox="0 0 24 24"><path d="M4 7h16M4 12h16M4 17h10"/></svg><div class="t">Third-Party Admins</div><div class="d">End-to-end claim handling</div></div>
        <div class="cell"><svg viewBox="0 0 24 24"><path d="M12 3v18M5 8h14M5 16h14"/></svg><div class="t">Uninsured Employers</div><div class="d">UEBTF representation</div></div>
        <div class="cell"><svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 3.6-7 8-7s8 3 8 7"/></svg><div class="t">Self-Insured</div><div class="d">Programs &amp; entities</div></div>
      </div>
    </div>
  </section>

  <!-- ===== COVERAGE (signature) ===== -->
  <section class="coverage" id="coverage">
    <div class="wrap">
      <div class="sec-head reveal">
        <span class="eyebrow">Statewide WCAB coverage</span>
        <h2>From San Diego to San Francisco.</h2>
        <p>Two offices let us appear across California — covering nineteen Workers' Compensation Appeals Board venues, north and south.</p>
      </div>
      <div class="cov-grid">
        <div class="venues">
          <div class="col reveal">
            <h3><span class="dot"></span> Southern California</h3>
            <div class="office">Orange County Office</div>
            <ul>
              <li>Anaheim</li><li>Bakersfield</li><li>Long Beach</li><li>Los Angeles</li>
              <li>Marina del Rey</li><li>Oxnard</li><li>Pomona</li><li>Riverside</li>
              <li>San Bernardino</li><li>San Diego</li><li>San Luis Obispo</li><li>Santa Ana</li>
              <li>Van Nuys</li>
            </ul>
          </div>
          <div class="col reveal">
            <h3><span class="dot"></span> Northern California</h3>
            <div class="office">Sacramento Office</div>
            <ul>
              <li>Fresno</li><li>Oakland</li><li>Sacramento</li>
              <li>San Francisco</li><li>San Jose</li><li>Stockton</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== ATTORNEYS ===== -->
  <section class="team" id="team">
    <div class="wrap">
      <div class="sec-head center reveal">
        <span class="eyebrow">The team</span>
        <h2>Meet Your Trusted Team of Attorneys</h2>
        <p>Our named partners and full team of attorneys set the standard for the firm across our offices.</p>
        <div class="cta-row" style="justify-content:center;margin-top:32px">
          <a href="https://www.defendmelaw.com/attorneys" class="btn btn-gold">View attorney profiles</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="cta" id="contact">
    <div class="wrap">
      <span class="eyebrow" style="color:var(--gold-lite)">Partner with us</span>
      <h2 style="margin-top:16px">Excellent results, at every step from inception to closure.</h2>
      <p>Tell us about your matter and we'll show you how our firm can protect your exposure and control your costs.</p>
      <div class="cta-row">
        <a href="tel:+19493730777" class="btn btn-gold">Call 949.373.0777</a>
        <a href="mailto:info@defendmelaw.com" class="btn btn-ghost">Request a consultation</a>
      </div>
    </div>
  </section>
</main>

<footer>
  <div class="wrap">
    <div class="foot-grid">
      <div>
        <a href="#top" class="logo" style="margin-bottom:18px">
          <svg viewBox="0 0 219 148" style="height:46px"><use href="#meMono"/></svg>
          <span class="lockup"><span class="firm">MACDONALD EBBING &amp; LLOYD</span><span class="sub">L L P</span></span>
        </a>
        <p style="font-size:14.5px;max-width:34ch;margin-top:6px">Results-focused California workers' compensation defense for employers, carriers, and administrators.</p>
      </div>
      <div>
        <h4>Firm</h4>
        <ul>
          <li><a href="#about">About Us</a></li>
          <li><a href="#difference">Why Us</a></li>
          <li><a href="#team">Attorneys</a></li>
          <li><a href="#serve">Who We Serve</a></li>
          <li><a href="https://www.defendmelaw.com/firm-news">Firm News</a></li>
        </ul>
      </div>
      <div>
        <h4>Offices</h4>
        <ul>
          <li>Orange County, CA</li>
          <li>Sacramento, CA</li>
          <li>San Diego, CA</li>
          <li style="color:var(--gold);font-size:11px;letter-spacing:.14em;text-transform:uppercase;margin-top:14px;padding-bottom:0">Central Mailing Address</li>
          <li style="padding-top:4px">999 Corporate Drive,<br>Suite 100</li>
          <li>Ladera Ranch, CA 92694</li>
        </ul>
      </div>
      <div>
        <h4>Contact</h4>
        <ul>
          <li><a href="tel:+19493730777">p 949.373.0777</a></li>
          <li>f 949.334.0108</li>
          <li><a href="mailto:info@defendmelaw.com">info@defendmelaw.com</a></li>
        </ul>
      </div>
    </div>
    <div class="foot-bottom">
      <span>© 2026 MacDonald Ebbing &amp; Lloyd, LLP. All rights reserved.</span>
      <span>Attorney advertising. Prior results do not guarantee a similar outcome.</span>
    </div>
  </div>
</footer>

<script>
  // mobile menu
  var t=document.querySelector('.menu-toggle'),m=document.getElementById('menu');
  t.addEventListener('click',function(){var o=m.classList.toggle('open');t.setAttribute('aria-expanded',o)});
  m.querySelectorAll('a').forEach(function(a){a.addEventListener('click',function(){m.classList.remove('open');t.setAttribute('aria-expanded',false)})});
  // scroll reveal
  var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target)}})},{threshold:.14});
  document.querySelectorAll('.reveal').forEach(function(el){io.observe(el)});
</script>
{squarespace-footers}
</body>
</html>
