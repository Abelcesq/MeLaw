<!doctype html>
<html {.if authenticatedAccount}data-authenticated-account{.end}>
  <head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="initial-scale=1">

    {squarespace-headers}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
      /* === ME Law interior-page banner & cream framing (site.region only) === */
      :root{
        --me-navy:#0F1E33; --me-navy-deep:#0A1626; --me-navy-panel:#15263F;
        --me-gold:#C9A227; --me-gold-lite:#E4C766; --me-cream:#F6F3EC;
        --me-ink:#1C2533; --me-line:rgba(255,255,255,.12);
        --me-serif:'Fraunces',Georgia,serif; --me-sans:'Inter',system-ui,sans-serif;
      }
      /* hide the default Squarespace header (we replace it with the navy banner) */
      .Site > .Header--top,
      .Site-inner .Header--bottom { display:none !important; }
      /* cream page background for UI consistency with the homepage */
      body, .Site, .Site-inner, .Content-outer { background:var(--me-cream) !important; }

      /* ---- sticky navy banner ---- */
      .me-bar{
        position:sticky; top:0; z-index:9999;
        background:linear-gradient(180deg,var(--me-navy) 0%,var(--me-navy-deep) 100%);
        box-shadow:0 8px 30px -18px rgba(0,0,0,.6); font-family:var(--me-sans);
      }
      .me-bar .me-wrap{ max-width:1180px; margin:0 auto; padding:0 32px; }
      .me-bar .me-top{ border-bottom:1px solid var(--me-line); }
      .me-bar .me-top .me-wrap{
        display:flex; justify-content:flex-end; gap:26px; padding:10px 32px;
        font-size:12.5px; color:rgba(255,255,255,.72); letter-spacing:.03em;
      }
      .me-bar .me-top a{ color:rgba(255,255,255,.72); text-decoration:none; }
      .me-bar .me-top a:hover{ color:var(--me-gold-lite); }
      .me-bar .me-nav{
        display:flex; align-items:center; justify-content:space-between; gap:24px;
        padding-top:16px; padding-bottom:16px; flex-wrap:wrap;
      }
      .me-bar .me-logo{ display:flex; align-items:center; gap:14px; text-decoration:none; }
      .me-bar .me-logo svg{ display:block; height:40px; width:auto; }
      .me-bar .me-logo .me-firm{ font-weight:600; font-size:12.5px; letter-spacing:.13em; color:#fff; }
      /* editable nav rendered by header-nav.block */
      .me-bar .Header-nav-inner{ display:flex; align-items:center; gap:28px; flex-wrap:wrap; }
      .me-bar .Header-nav-item{
        font-family:var(--me-sans); font-size:13.5px; font-weight:500; letter-spacing:.04em;
        color:rgba(255,255,255,.85) !important; text-decoration:none;
        padding-bottom:4px; border-bottom:1.5px solid transparent; transition:.2s;
      }
      .me-bar .Header-nav-item:hover,
      .me-bar .Header-nav-item--active{ color:#fff !important; border-color:var(--me-gold); }

      /* folder ("Attorneys") title behaves like a top-level nav item */
      .me-bar .Header-nav-folder-title{
        font-family:var(--me-sans); font-size:13.5px; font-weight:500; letter-spacing:.04em;
        color:rgba(255,255,255,.85) !important; text-decoration:none;
        padding-bottom:4px; border-bottom:1.5px solid transparent; transition:.2s;
      }
      .me-bar .Header-nav-folder-title:hover,
      .me-bar .Header-nav-folder-title--active{ color:#fff !important; border-color:var(--me-gold); }
      /* dropdown panel: white background, navy-blue names that stand out */
      .me-bar .Header-nav-folder{
        background:#fff !important; border:1px solid rgba(15,30,51,.12);
        border-radius:3px; box-shadow:0 18px 40px -20px rgba(15,30,51,.55);
        padding:8px 0 !important; margin-top:8px; min-width:210px;
      }
      .me-bar .Header-nav-folder-item{
        display:block; font-family:var(--me-sans); font-size:13px; font-weight:500;
        letter-spacing:.02em; color:var(--me-navy-panel) !important;
        padding:8px 20px !important; white-space:nowrap; border-bottom:0 !important;
      }
      .me-bar .Header-nav-folder-item:hover,
      .me-bar .Header-nav-folder-item--active{
        color:var(--me-gold) !important; background:rgba(15,30,51,.05);
      }

      /* ---- white content card on the cream frame ---- */
      .Content-outer{ padding:48px 24px 80px !important; }
      .Content-outer .Main{
        background:#fff !important; max-width:1080px; margin:0 auto !important;
        border:1px solid rgba(15,30,51,.10); border-radius:4px;
        box-shadow:0 30px 60px -45px rgba(15,30,51,.5); padding:40px !important;
      }

      /* ---- navy footer to match the top banner ---- */
      .Footer{
        background:linear-gradient(180deg,var(--me-navy) 0%,var(--me-navy-deep) 100%) !important;
        font-family:var(--me-sans) !important;
        color:rgba(255,255,255,.82) !important;
      }
      .Footer,
      .Footer a,
      .Footer .Footer-business-info-item,
      .Footer .Footer-nav-item{ color:rgba(255,255,255,.82) !important; }
      .Footer h1,.Footer h2,.Footer h3,.Footer h4,
      .Footer .Footer-business-info-item--name{ color:#fff !important; }
      .Footer a:hover,
      .Footer .Footer-nav-item:hover{ color:var(--me-gold-lite) !important; }
      /* location buttons (footer content blocks): gold-bordered on navy */
      .Footer .sqs-block-button-element{
        border-color:var(--me-gold) !important; color:#fff !important;
        letter-spacing:.14em !important;
      }
      .Footer .sqs-block-button-element:hover{
        background:var(--me-gold) !important; color:var(--me-navy-deep) !important;
      }

      @media(max-width:760px){
        .me-bar .me-nav{ justify-content:center; }
        .me-bar .me-top .me-wrap{ justify-content:center; }
        .Content-outer{ padding:24px 12px 56px !important; }
        .Content-outer .Main{ padding:22px !important; }
      }
    </style>
  </head>
  <body id="{squarespace.page-id}" class="{squarespace.page-classes} sqs-has-custom-cart{.if website.logoImageUrl} has-logo-image{.or} has-site-title{.end}{.if website.siteTagLine} has-tagline{.end}{.if website.socialAccounts.0} has-social{.end}{.if showCart} has-cart{.end}{.if item}{.or}{.equal? collection.typeName "index"}{.section collection}{.repeated section collections}{.background-source-video?} has-parallax-images{.or}{.section mainImage} has-parallax-images{.end}{.end}{.end}{.end}{.or}{.section collection}{.background-source-video?} has-parallax-images{.or}{.section mainImage} has-parallax-images{.end}{.end}{.end}{.end}{.end} enable-load-effects<squarespace:navigation navigationId="mainNavigation">{.if items.0} has-primary-nav{.end}</squarespace:navigation><squarespace:navigation navigationId="secondaryNavigation">{.if items.0} has-secondary-nav{.end}</squarespace:navigation><squarespace:navigation navigationId="footerMainNavigation">{.if items.0} has-footer-nav{.end}</squarespace:navigation>{.equal? collection.typeName "index"}{.section collection}{.section collections.0}{.equal? typeName "gallery"} has-index-gallery-first{.end}{.end}{.end}{.end}{.if userAccountsContext.showSignInLink} has-user-accounts{.end}" data-controller="HashManager, MobileClassname">

    <div class="Loader"></div>

    {@|apply mobile.block}

    <div class="Parallax-host-outer">
      <div class="Parallax-host" data-parallax-host>
        {.equal? collection.typeName "index"}
          {.section collection}
            {.repeated section collections}
              {.var @collectionId id}
              {.background-source-video?}
                <div class="Parallax-item" data-parallax-item data-parallax-id="{@collectionId}"></div>
              {.or}
                {.section mainImage}
                  <div class="Parallax-item" data-parallax-item data-parallax-id="{@collectionId}"></div>
                {.end}
              {.end}
            {.end}
          {.end}
        {.or}
          {.equal? collection.typeName "products"}
          {#  The system Product collection does not support video backgrounds  }
            {.section collection}
              {.var @collectionId id}
              {.section mainImage}
                <div class="Parallax-item" data-parallax-item data-parallax-id="{@collectionId}"></div>
              {.end}
            {.end}
          {.or}
            {.if item}{.or}
              {.section collection}
                {.var @collectionId id}
                {.background-source-video?}
                  <div class="Parallax-item" data-parallax-item data-parallax-id="{@collectionId}"></div>
                {.or}
                  {.section mainImage}
                    <div class="Parallax-item" data-parallax-item data-parallax-id="{@collectionId}"></div>
                  {.end}
                {.end}
              {.end}
            {.end}
          {.end}
        {.end}
      </div>
    </div>

    <div class="Site" data-nc-base="header" data-controller="AncillaryLayout">
      <div class="sqs-announcement-bar-dropzone"></div>

      <!-- ===== ME Law sticky navy banner (matches homepage header) ===== -->
      <svg width="0" height="0" style="position:absolute" aria-hidden="true"><defs>
        <linearGradient id="meMonoGrad" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0" stop-color="#E4C766"/><stop offset="1" stop-color="#B8901E"/>
        </linearGradient>
        <g id="meMonoBar">
          <rect x="8" y="8" width="27" height="132" fill="url(#meMonoGrad)"/>
          <rect x="92" y="8" width="27" height="132" fill="url(#meMonoGrad)"/>
          <path d="M8 8 L35 8 L75 100 L48 100 Z" fill="url(#meMonoGrad)"/>
          <path d="M119 8 L92 8 L52 100 L79 100 Z" fill="url(#meMonoGrad)"/>
          <rect x="131" y="8" width="25" height="132" fill="url(#meMonoGrad)"/>
          <rect x="131" y="8" width="80" height="25" fill="url(#meMonoGrad)"/>
          <rect x="131" y="66" width="62" height="24" fill="url(#meMonoGrad)"/>
          <rect x="131" y="115" width="80" height="25" fill="url(#meMonoGrad)"/>
          <text x="167" y="109" font-family="Inter,sans-serif" font-size="15" font-weight="600" letter-spacing="3.5" fill="url(#meMonoGrad)">LAW</text>
        </g>
      </defs></svg>
      <header class="me-bar" role="banner">
        <div class="me-top">
          <div class="me-wrap">
            <a href="tel:+19493730777">p 949.373.0777</a>
            <span>Orange County &middot; Sacramento &middot; San Diego</span>
          </div>
        </div>
        <div class="me-wrap me-nav">
          <a href="/" class="me-logo" aria-label="MacDonald Ebbing &amp; Lloyd, LLP home">
            <svg viewBox="0 0 219 148" role="img"><use href="#meMonoBar"/></svg>
            <span class="me-firm">MACDONALD EBBING &amp; LLOYD, LLP</span>
          </a>
          <nav aria-label="Primary">
            <squarespace:navigation navigationId="mainNavigation" template="header-nav" />
          </nav>
        </div>
      </header>

      <header class="Header Header--top">
        <div class="Header-inner Header-inner--top" data-nc-group="top">
          <div data-nc-container="top-left">

            <div class="Header-search" data-nc-element="search">
              <form class="Header-search-form" action="/search" method="get" role="search">
                <input class="Header-search-form-input" name="q" type="text" spellcheck="false" value="" autocomplete="off" placeholder="{localizedStrings.search}" aria-label="{localizedStrings.search}"/>
                <button class="Header-search-form-submit" type="submit" data-test="template-search" aria-label="{localizedStrings.search}">
                  <svg class="Icon Icon--search--small" viewBox="0 0 15 15">
                    <use xlink:href="/assets/ui-icons.svg#search-icon--small"></use>
                  </svg>
                  <svg class="Icon Icon--search" viewBox="0 0 20 20">
                    <use xlink:href="/assets/ui-icons.svg#search-icon"></use>
                  </svg>
                </button>
              </form>
            </div>

          </div>
          <div data-nc-container="top-center">
            {.if userAccountsContext.showSignInLink}
              <div class="Header-account" data-nc-element="account" data-controller="UserAccountLink">
                <button class="user-accounts-text-link">
                  <span class="unauth">{localizedStrings.signIn}</span>
                  <span class="auth">{localizedStrings.myAccount}</span>
                </button>
                <div class="user-accounts-icon">
                  {@|apply user-account-icon.block}
                </div>
              </div>
            {.end}
            {.if website.socialAccounts.0}
              <div class="Header-social" data-nc-element="social">
                {@|apply social-links.block}
              </div>
            {.end}
          </div>
          <div data-nc-container="top-right">

            {@|apply cart.block}

          </div>
        </div>
      </header>

      <div class="Site-inner{.equal? collection.typeName "index"} Site-inner--index{.end}"{.equal? collection.typeName "index"}{.section collection}{.section collections.0}{.equal? typeName "page"}{.background-source-video?} data-controller="HeaderOverlay"{.or}{.section mainImage} data-controller="HeaderOverlay"{.end}{.end}{.end}{.equal? typeName "gallery"} data-controller="HeaderOverlay"{.end}{.end}{.end}{.or}{.if item}{.or}{.section collection}{.background-source-video?} data-controller="HeaderOverlay"{.or}{.section mainImage} data-controller="HeaderOverlay"{.end}{.end}{.end}{.end}{.end}>

        <header class="Header Header--bottom{.if item}{.or}{.equal? collection.typeName "index"}{.section collection}{.section collections.0}{.equal? typeName "page"}{.background-source-video?} Header--overlay{.or}{.section mainImage} Header--overlay{.end}{.end}{.end}{.equal? typeName "gallery"} Header--index-gallery{.end}{.end}{.end}{.or}{.section collection}{.background-source-video?} Header--overlay{.or}{.section mainImage} Header--overlay{.end}{.end}{.end}{.end}{.end}">
          <div class="Header-inner Header-inner--bottom" data-nc-group="bottom">
            <div data-nc-container="bottom-left">
              <nav class="Header-nav Header-nav--primary" data-nc-element="primary-nav" data-content-field="navigation">
                <squarespace:navigation navigationId="mainNavigation" template="header-nav" />
              </nav>
            </div>
            <div data-nc-container="bottom-center">

              <a href="/" class="Header-branding" data-nc-element="branding" data-content-field="site-title">
                {.section website}
                  {.section logoImageUrl}
                    {#  sizes is set to max width for tweak-header-branding-logo-width  }
                    {.ctx @image src=logoImageUrl alt=siteTitle}
                    {@image|apply/apply-image-component.block/
                      /class=Header-branding-logo/
                      /sizes=320px/
                      /elementTiming=wf-header-branding-logo/
                    }
                  {.or}
                    {siteTitle}
                  {.end}
                {.end}
              </a>
              {.section website}{.section siteTagLine}<div class="Header-tagline" data-nc-element="tagline">{@}</div>{.end}{.end}

            </div>
            <div data-nc-container="bottom-right">

              <nav class="Header-nav Header-nav--secondary" data-nc-element="secondary-nav" data-content-field="navigation">
                <squarespace:navigation navigationId="secondaryNavigation" template="header-nav" />
              </nav>

            </div>
          </div>
        </header>

        <div class="Content-outer">
          {.if collection}{.if item}{.or}{.equal? collection.typeName "index"}{.or}
            {.equal? collection.typeName "page"}
              {.section collection}
                {.background-source-video?}
                  {@|apply intro.block}
                {.or}
                  {.if mainImage}
                    {@|apply intro.block}
                  {.end}
                {.end}
              {.end}
            {.or}
              {collection|apply intro.block}
            {.end}
          {.end}{.end}{.end}

          <main class="{.equal? collection.typeName "index"}Index{.if collection.collections.0}{.or} Index--empty{.end}{.or}Main{.if collection.typeName} Main--{collection.typeName}{.equal? collection.typeName "page"}{.or}{.if item}-item{.or}-list{.end}{.end}{.end}{.end}" {.equal? collection.typeName "index"}data-collection-id="{collection.id}"{.end}{.equal? collection.typeName "index"} data-controller="IndexFirstSectionHeight, Parallax, IndexNavigation"{.end}>
            {.equal? collection.typeName "index"}
              {squarespace.main-content}
            {.or}
              <section class="Main-content" data-content-field="main-content">
                {squarespace.main-content}
              </section>
            {.end}
          </main>

        </div>
      </div>

      {@|apply footer.block}

    </div>

    <squarespace:script src="site-bundle.js" combo="false" />

    {squarespace-footers}

  </body>
</html>
